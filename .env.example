# Skopiuj do .env i uzupełnij. .env jest w .gitignore — nie commituj.

# --- Cloudflare: JEDNO konto, token SCOPED (NIE 'wrangler login') ---
# Token: dash → My Profile → API Tokens → "Edit Cloudflare Workers",
# Account Resources = TYLKO to jedno konto. Wtedy projekt fizycznie nie
# dosięgnie innych kont — zły account_id czy bug = odmowa API, nie wyciek.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Proxy głosowy (opcjonalne) ---
ANTHROPIC_API_KEY=
PORT=3000
