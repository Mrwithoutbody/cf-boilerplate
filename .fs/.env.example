# Skopiuj do .env i uzupełnij. .env jest w .gitignore — nie commituj.

# --- Cloudflare: JEDNO konto, token zawężony (NIE 'wrangler login') ---
# Token: dash.cloudflare.com/profile/api-tokens → Create Token
# → szablon "Edit Cloudflare Workers" → Use template
# → Account Resources = Include > Specific account > TO jedno konto.
# Zawężenie do jednego konta = izolacja: inne konta nieosiągalne, zły
# account_id czy bug = odmowa API, nie wyciek. NIE 'wrangler login' (OAuth
# widzi wszystkie konta). ACCOUNT_ID z URL konta w dashboardzie.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Proxy głosowy (opcjonalne) ---
# Proxy woła lokalny 'claude' (Claude Code). Domyślnie: Twoja sesja/abonament
# (~/.claude) — ZOSTAW PUSTY. Wypełnij tylko gdy świadomie chcesz płatne API.
ANTHROPIC_API_KEY=
PORT=3000
