# Opcjonalny override wykrywania targetu (skopiuj do .fs/target.env).
# Bez tego pliku futurestack sam wykrywa stack z providerów w .fs/targets/.
# Użyj gdy: autodetekcja się myli, albo masz stack nieobjęty providerem.

# Wymuś konkretny provider (nazwa = plik w .fs/targets/ bez NN- i .sh):
#FS_TARGET=cloudflare-pages

# Albo podaj własne komendy (biją autodetekcję):
#FS_DEPLOY=npm run deploy
#FS_PREVIEW=npm run preview
#FS_DEV=npm run dev

# Czy target wymaga creds Cloudflare (1) czy nie (0, np. Expo/static):
#FS_NEEDS_CF=0

# Dodatkowe komendy które Claude może odpalać z telefonu (poza git/npm/wrangler).
# Lista po przecinku, każda → Bash(<x>:*). Dla nie-npm stacków (Rust/Go/...).
#FS_ALLOW=cargo,go,pnpm,bun

# Jawny URL podglądu aplikacji w UI telefonu (gdy autodetekcja nie trafia,
# np. custom domain, Pages z inną subdomeną, Expo web).
#FS_APP_URL=https://moja-apka.example.com
